# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# AI / Claude Cloud billing
# Optional: initial credit to calculate estimated remaining balance in the header usage pill.
AI_CLOUD_CREDIT_BRL=100.00
# Or use USD instead of BRL:
# AI_CLOUD_CREDIT_USD=20.00

# Optional: Admin API keys (NOT the regular API key used to call the models) to pull the
# REAL monthly spend from each provider's own billing ledger instead of our own per-call
# estimate. Neither provider exposes the remaining prepaid credit via API — only spend —
# so the "crédito total" above still has to be set manually.
# Anthropic: Console > Settings > Admin API Keys (starts with sk-ant-admin...)
# ANTHROPIC_ADMIN_API_KEY=sk-ant-admin01-...
# OpenAI: platform.openai.com > Settings > Admin keys (org owner only)
# OPENAI_ADMIN_API_KEY=sk-admin-...

# ── WhatsApp Providers ────────────────────────────────────────────────────────

# Evolution API (used when whatsapp_provider = 'evolution' for a client)
# Base URL of your self-hosted Evolution API instance
EVOLUTION_API_URL=http://your-server-ip:8080

# Global API key for the Evolution API instance
EVOLUTION_API_KEY=your-evolution-api-key-here

# Z-API is configured per-client via the dashboard (no global env vars needed)
