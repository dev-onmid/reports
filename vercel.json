{
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/reports/cron-monthly?secret=${CRON_SECRET}",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/alerts/balance-cron?secret=${CRON_SECRET}",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/otimizador/daily?secret=${CRON_SECRET}",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/leadlovers/worker?secret=${CRON_SECRET}",
      "schedule": "0 * * * 1-5"
    }
  ]
}
