{
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/alerts/balance-cron?secret=${CRON_SECRET}",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/otimizador/weekly?secret=${CRON_SECRET}",
      "schedule": "0 10 * * 1-5"
    },
    {
      "path": "/api/leadlovers/worker?secret=${CRON_SECRET}",
      "schedule": "0 12 * * 1-5"
    }
  ]
}
